<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YouTube Search Player</title>

<style>
*{
    box-sizing:border-box;
    margin:0;
    padding:0;
}

body{
    font-family:Arial,sans-serif;
    background:#111;
    color:white;
    padding:20px;
}

h1{
    text-align:center;
    margin-bottom:1rem;
    font-size:22px;
}

.section-label{
    font-size:12px;
    color:#888;
    margin-bottom:4px;
}

.search-row{
    display:flex;
    gap:8px;
    margin-bottom:12px;
}

.search-row input{
    flex:1;
    padding:9px 12px;
    background:#222;
    border:1px solid #444;
    border-radius:8px;
    color:#fff;
    font-size:14px;
    outline:none;
}

.search-row input:focus{
    border-color:#888;
}

.search-row button{
    padding:9px 14px;
    background:#333;
    border:1px solid #555;
    border-radius:8px;
    color:#fff;
    cursor:pointer;
    font-size:14px;
    white-space:nowrap;
}

.search-row button:hover{
    background:#444;
}

#player{
    width:100%;
    margin-bottom:1rem;
}

#player iframe{
    width:100%;
    height:500px;
    border:none;
    border-radius:10px;
    display:block;
}

.results{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
    gap:15px;
}

.card{
    background:#222;
    border-radius:10px;
    overflow:hidden;
}

.card img{
    width:100%;
    display:block;
}

.card-body{
    padding:10px;
}

.card-body h3{
    font-size:13px;
    margin-bottom:4px;
    line-height:1.4;
}

.card-body p{
    font-size:12px;
    color:#aaa;
    margin-bottom:8px;
}

.card-btns{
    display:flex;
    gap:6px;
    flex-wrap:wrap;
}

.card-btns button{
    font-size:12px;
    padding:5px 9px;
    background:#333;
    border:1px solid #555;
    border-radius:6px;
    color:#fff;
    cursor:pointer;
}

.card-btns button:hover{
    background:#444;
}

.status{
    color:#aaa;
    font-size:14px;
    padding:1rem 0;
}

/* Top-right controls */
.top-controls{
    position:fixed;
    top:15px;
    right:15px;
    display:flex;
    flex-direction:column;
    gap:8px;
    z-index:9999;
}

/* Hub button left, then input, then Play button */
.id-row{
    display:flex;
    gap:6px;
    align-items:center;
}

.id-row input{
    width:220px;
    padding:8px 10px;
    background:#222;
    border:1px solid #444;
    border-radius:8px;
    color:white;
    outline:none;
}

.id-row input:focus{
    border-color:#888;
}

.id-row button,
.hub-btn{
    padding:8px 12px;
    background:#333;
    border:1px solid #555;
    border-radius:8px;
    color:white;
    cursor:pointer;
    white-space:nowrap;
}

.id-row button:hover,
.hub-btn:hover{
    background:#444;
}
</style>
</head>

<body>

<div class="top-controls">
    <div class="id-row">
        <!-- Hub button is now on the LEFT -->
        <button class="hub-btn" onclick="openHubInNewTab()">Open Hub In New Tab</button>

        <input
            type="text"
            id="idInput"
            placeholder="Video ID or URL"
            onkeydown="if(event.key==='Enter')playById()">

        <button onclick="playById()">▶ Play</button>
    </div>
</div>

<h1>YouTube Search</h1>

<div class="section-label">Search by keyword</div>

<div class="search-row">
    <input
        type="text"
        id="searchInput"
        placeholder="Search YouTube..."
        onkeydown="if(event.key==='Enter')searchVideos()">

    <button onclick="searchVideos()">Search</button>
</div>

<div id="player"></div>
<div id="results" class="results"></div>

<script>
const API_KEY = "YOUTUBE_API_KEY_HERE";

function extractVideoId(raw){
    let id = raw;
    try{
        const url = new URL(raw);
        id = url.searchParams.get("v") || url.pathname.split("/").pop();
    }catch(e){}
    return id;
}

function playById(){
    const raw = document.getElementById("idInput").value.trim();
    if(!raw) return;
    playVideo(extractVideoId(raw));
}

function playVideo(videoId){
    document.getElementById("player").innerHTML = `
        <iframe
            src="https://www.youtube.com/embed/${videoId}?autoplay=1"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen>
        </iframe>
    `;
    window.scrollTo({ top:0, behavior:"smooth" });
}

async function searchVideos(){
    const query = document.getElementById("searchInput").value.trim();
    if(!query) return;

    const resultsDiv = document.getElementById("results");
    resultsDiv.innerHTML = '<p class="status">Loading...</p>';

    try{
        const url = `https://www.googleapis.com/youtube/v3/search?part=snippet&maxResults=20&type=video&q=${encodeURIComponent(query)}&key=${API_KEY}`;
        const res = await fetch(url);
        const data = await res.json();

        resultsDiv.innerHTML = "";

        if(!data.items || !data.items.length){
            resultsDiv.innerHTML = '<p class="status">No videos found.</p>';
            return;
        }

        data.items.forEach(item => {
            const vid = item.id.videoId;
            const card = document.createElement("div");
            card.className = "card";
            card.innerHTML = `
                <img src="${item.snippet.thumbnails.medium.url}">
                <div class="card-body">
                    <h3>${item.snippet.title}</h3>
                    <p>${item.snippet.channelTitle}</p>
                    <div class="card-btns">
                        <button onclick="playVideo('${vid}')">▶ Play Here</button>
                        <button onclick="window.open('https://www.youtube.com/watch?v=${vid}','_blank')">Open Video</button>
                        <button onclick="window.open('https://www.youtube.com/shorts/${vid}','_blank')">Open Short</button>
                    </div>
                </div>
            `;
            resultsDiv.appendChild(card);
        });

    }catch(err){
        resultsDiv.innerHTML = '<p class="status">Error loading videos.</p>';
    }
}

function openHubInNewTab(){
    // Grab this page's full HTML
    const pageHTML = document.documentElement.outerHTML;

    // Open a blank new tab and write the page into it
    const newTab = window.open("about:blank", "_blank");
    if(newTab){
        newTab.document.open();
        newTab.document.write(pageHTML);
        newTab.document.close();
    }

    // Replace current tab with Google so it drops out of history
    location.replace("https://www.google.com");
}
</script>

</body>
</html>
